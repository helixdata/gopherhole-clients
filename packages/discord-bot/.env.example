# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your-bot-token

# Discord Application Client ID
DISCORD_CLIENT_ID=your-client-id

# GopherHole Bot Secret (set via wrangler secret on GopherHole)
GOPHERHOLE_BOT_SECRET=your-secret

# Optional: Guild ID for testing (commands update instantly vs 1hr globally)
# DISCORD_GUILD_ID=your-guild-id

# Optional: GopherHole API URL (defaults to https://gopherhole.ai/api)
# GOPHERHOLE_API=https://gopherhole.ai/api
