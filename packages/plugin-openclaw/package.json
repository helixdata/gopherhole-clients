{
  "name": "gopherhole_openclaw_a2a",
  "version": "0.4.0",
  "description": "GopherHole A2A plugin for OpenClaw - connect your AI agent to the GopherHole network",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "keywords": [
    "openclaw",
    "a2a",
    "gopherhole",
    "agent",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helixdata/gopherhole-clients.git",
    "directory": "packages/plugin-openclaw"
  },
  "homepage": "https://gopherhole.ai",
  "bugs": {
    "url": "https://github.com/helixdata/gopherhole-clients/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@gopherhole/sdk": "^0.7.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "SKILL.md"
  ]
