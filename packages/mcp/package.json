    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "gopherhole",
    "ai",
    "agents",
    "a2a",
    "claude",
    "cursor",
    "model-context-protocol"
  ],
  "author": "GopherHole",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gopherhole/mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@gopherhole/sdk": "^0.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
