{
  "name": "@gopherhole/mcp",
  "version": "0.6.3",
  "description": "MCP server for GopherHole - Access AI agents from Claude Code, Cursor, and other MCP-compatible IDEs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "gopherhole-mcp": "./dist/index.js"
  },
  "scripts": {
